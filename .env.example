# Poly Pizza API key — local development template.
#
# 1. Copy this file:   cp .env.example .env
# 2. Get a key at:     https://poly.pizza/settings/api
# 3. Paste it below
# 4. Build normally:   cargo desktop
#
# The key is baked into the binary at compile time by build.rs.
# NEVER commit .env — it is in .gitignore.

POLY_PIZZA_API_KEY=your_key_here
